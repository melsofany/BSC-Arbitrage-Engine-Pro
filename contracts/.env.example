# ============================================================================
# ENVIRONMENT VARIABLES FOR MULTI-PATH FLASH ARBITRAGE ENGINE
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control!
# ============================================================================

# Your wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# BSC RPC URLs
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/

# WebSocket URL for real-time event monitoring
BSC_WSS_URL=wss://bsc-ws-node.nariox.org:443

# BscScan API Key (for contract verification)
BSCSCAN_API_KEY=your_bscscan_api_key_here

# Deployed contract address (set after deployment)
CONTRACT_ADDRESS=0x_your_contract_address_here
